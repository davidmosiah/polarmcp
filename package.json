{
  "name": "polar-mcp-unofficial",
  "version": "0.3.4",
  "description": "Unofficial local-first Polar AccessLink Dynamic API v4 MCP server for AI health, sleep and training agents.",
  "type": "module",
  "bin": {
    "polar-mcp-unofficial": "dist/index.js",
    "polar-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "server.json",
    "docs/.nojekyll",
    "docs/.well-known",
    "docs/assets",
    "docs/*.md",
    "docs/*.txt",
    "docs/*.xml",
    "docs/index.html",
    "examples",
    "llms.txt"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "smoke": "node scripts/smoke-tools.mjs",
    "test": "npm run typecheck && npm run build && npm run smoke && npm run smoke:http && npm run test:summary && npm run test:privacy-cache && npm run test:http-retry && npm run test:http-cache && npm run test:cli-ux && npm run test:agent-readiness && npm run test:hermes-agent && npm run test:metadata",
    "test:summary": "node scripts/summary-fixture-test.mjs",
    "prepublishOnly": "npm test",
    "smoke:http": "node scripts/smoke-http.mjs",
    "test:privacy-cache": "node scripts/privacy-cache-test.mjs",
    "test:http-retry": "node scripts/http-retry-test.mjs",
    "test:http-cache": "node scripts/http-cache-test.mjs",
    "test:cli-ux": "node scripts/cli-ux-test.mjs",
    "test:agent-readiness": "node scripts/agent-readiness-test.mjs",
    "test:hermes-agent": "node scripts/hermes-agent-manifest-test.mjs",
    "test:metadata": "node scripts/metadata-check.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "polar",
    "health",
    "sleep",
    "heart-rate",
    "fitness",
    "ai-agents"
  ],
  "author": "David Mosiah",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.21.0",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidmosiah/polarmcp.git"
  },
  "bugs": {
    "url": "https://github.com/davidmosiah/polarmcp/issues",
    "email": "support@delx.ai"
  },
  "homepage": "https://wellness.delx.ai/connectors/polar",
  "mcpName": "io.github.davidmosiah/polarmcp",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js"
}
